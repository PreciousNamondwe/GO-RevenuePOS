generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          Int      @id @default(autoincrement())
  role_key    String   @unique
  role_label  String
  description String?
  color       String   @default("#5C8CE8")
  is_deleted  Int      @default(0)
  is_synced   Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  users       User[]
  @@map("roles")
}

model User {
  id            Int       @id @default(autoincrement())
  user_id       String    @unique
  full_name     String
  role          String    @default("agent")
  pin_hash      String
  biometric_key String?
  is_active     Int       @default(1)
  is_deleted    Int       @default(0)
  is_synced     Int       @default(0)
  last_login    DateTime? @db.Timestamp(6)
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  sessions      Session[]
  audit_logs    AuditLog[]
  role_ref      Role      @relation(fields: [role], references: [role_key])
  @@map("user")
}

model Session {
  id            Int      @id @default(autoincrement())
  user_id       String
  jwt_token     String?
  refresh_token String?
  expires_at    DateTime @db.Timestamp(6)
  is_offline    Int      @default(0)
  is_deleted    Int      @default(0)
  is_synced     Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  user          User     @relation(fields: [user_id], references: [user_id])
  @@map("sessions")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    String
  action     String
  details    String?
  is_deleted Int      @default(0)
  is_synced  Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamp(6)
  user       User     @relation(fields: [user_id], references: [user_id])
  @@map("audit_logs")
}

model SyncQueue {
  id          Int      @id @default(autoincrement())
  table_name  String
  operation   String
  payload     String
  retry_count Int      @default(0)
  is_deleted  Int      @default(0)
  is_synced   Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  @@map("sync_queue")
}

model BusinessType {
  id            Int        @id @default(autoincrement())
  name          String     @unique
  description   String?
  amount_charge Float      @default(0)
  is_deleted    Int        @default(0)
  is_synced     Int        @default(0)
  created_at    DateTime   @default(now()) @db.Timestamp(6)
  businesses    Business[]
  @@map("business_types")
}

model BusinessOwner {
  id                        Int        @id @default(autoincrement())
  full_name                 String
  national_id               String?    @unique
  location                  String?
  date_of_birth             DateTime?  @db.Timestamp(6)
  allow_multiple_businesses Int        @default(0)
  max_businesses_count      Int        @default(1)
  is_deleted                Int        @default(0)
  is_synced                 Int        @default(0)
  created_at                DateTime   @default(now()) @db.Timestamp(6)
  businesses                Business[]
  @@map("business_owners")
}

model Business {
  id                  Int           @id @default(autoincrement())
  business_name       String
  registration_number String?       @unique
  business_type_id    Int
  owner_id            Int
  address             String?
  phone               String?
  email               String?
  tax_number          String?
  is_active           Int           @default(1)
  is_deleted          Int           @default(0)
  is_synced           Int           @default(0)
  created_at          DateTime      @default(now()) @db.Timestamp(6)
  business_type       BusinessType  @relation(fields: [business_type_id], references: [id])
  owner               BusinessOwner @relation(fields: [owner_id], references: [id])
  @@map("businesses")
}